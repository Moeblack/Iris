{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@irises/extension-sdk": ["./packages/extension-sdk/src"],
      "@irises/extension-sdk/utils": ["./packages/extension-sdk/src/utils"],
      "@irises/extension-sdk/tool-utils": ["./packages/extension-sdk/src/tool-utils"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/platforms/web/web-ui"]
}
