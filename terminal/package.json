{
  "name": "iris-terminal",
  "version": "1.0.0",
  "description": "Iris 终端命令界面集合 (OpenTUI)",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "dev:onboard": "bun run src/index.tsx onboard",
    "build": "bun run build.ts",
    "build:linux-x64": "bun build src/index.tsx --compile --target=bun-linux-x64 --outfile dist/iris-onboard-linux-x64",
    "build:linux-arm64": "bun build src/index.tsx --compile --target=bun-linux-arm64 --outfile dist/iris-onboard-linux-arm64",
    "build:darwin-arm64": "bun build src/index.tsx --compile --target=bun-darwin-arm64 --outfile dist/iris-onboard-darwin-arm64",
    "build:darwin-x64": "bun build src/index.tsx --compile --target=bun-darwin-x64 --outfile dist/iris-onboard-darwin-x64",
    "build:windows-x64": "bun build src/index.tsx --compile --target=bun-win32-x64 --outfile dist/iris-onboard-windows-x64"
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "react": "^19.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
